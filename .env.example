# Supabase — get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI — SERVER ONLY, never expose to browser
OPENAI_API_KEY=sk-proj-your_openai_key_here

# App URL (set to your Vercel domain in production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
